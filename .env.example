# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/admission_system?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRATION=7d

# CORS - Thêm URL Vercel của bạn sau khi deploy
CORS_ORIGIN=http://localhost:5173,https://your-frontend.vercel.app

# Server
PORT=5000
NODE_ENV=production